// Prisma Schema para App Financeiro

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("POSTGRES_URL")
}

// ===================================
// MODELOS
// ===================================

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String   @default("")
  email     String   @unique @default("")
  senha     String   @default("")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relações
  receitas  Receita[]
  despesas  Despesa[]
  insights  Insight[]

  @@map("usuarios")
}

model Receita {
  id            Int      @id @default(autoincrement())
  descricao     String   @default("")
  valor         Float
  tipo          String   @default("")
  dataRegistro  DateTime @default(now()) @map("data_registro")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relação com usuário
  usuarioId     Int      @map("usuario_id")
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, tipo])
  @@index([dataRegistro])
  @@map("receitas")
}

model Despesa {
  id                  Int      @id @default(autoincrement())
  descricao           String   @default("")
  valorParcela        Float    @map("valor_parcela")
  valorPrimeiraParcela Float?   @map("valor_primeira_parcela")
  tipo                String   @default("")
  dataInicio          DateTime @default(now()) @map("data_inicio")
  paga                Boolean  @default(false)
  dataPagamento       DateTime? @map("data_pagamento")
  parcelasTotal       Int      @default(1) @map("parcelas_total")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relação com usuário e pagamentos da despesa
  usuarioId           Int      @map("usuario_id")
  usuario             Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  pagamentos          PagamentoDespesa[]

  @@index([usuarioId, tipo])
  @@index([dataInicio])
  @@map("despesas")
}

model PagamentoDespesa {
  id              Int      @id @default(autoincrement())
  despesaId       Int      @map("despesa_id")
  mes             Int
  ano             Int
  valorPago       Float    @map("valor_pago")
  dataPagamento   DateTime @default(now()) @map("data_pagamento")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  despesa         Despesa  @relation(fields: [despesaId], references: [id], onDelete: Cascade)

  @@unique([despesaId, mes, ano])
  @@index([despesaId])
  @@map("pagamentos_despesa")
}

model Insight {
  id        Int      @id @default(autoincrement())
  mes       Int
  ano       Int
  conteudo  String   @default("")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relação com usuário
  usuarioId Int      @map("usuario_id")
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, mes, ano])
  @@index([usuarioId, mes, ano])
  @@map("insights")
}

